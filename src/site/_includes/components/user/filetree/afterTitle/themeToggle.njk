<div class="theme-toggle-wrapper" x-data="{
  isDark: true,
  init() {
    const saved = localStorage.getItem('dg-theme');
    if (saved === 'light') {
      this.isDark = false;
      document.body.classList.remove('theme-dark');
      document.body.classList.add('theme-light');
    } else {
      this.isDark = true;
      document.body.classList.remove('theme-light');
      document.body.classList.add('theme-dark');
    }
  },
  toggle() {
    this.isDark = !this.isDark;
    if (this.isDark) {
      document.body.classList.remove('theme-light');
      document.body.classList.add('theme-dark');
      localStorage.setItem('dg-theme', 'dark');
    } else {
      document.body.classList.remove('theme-dark');
      document.body.classList.add('theme-light');
      localStorage.setItem('dg-theme', 'light');
    }
  }
}" x-init="init()">
  <button type="button" class="theme-toggle-btn" @click="toggle()" :title="isDark ? '切换为浅色主题' : '切换为深色主题'" aria-label="切换主题">
    <svg x-show="!isDark" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/></svg>
    <svg x-show="isDark" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
  </button>
</div>
