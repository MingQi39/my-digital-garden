{% macro menuItem(fileOrFolderName, fileOrFolder, step, currentPath) %}
    {%if fileOrFolder.isNote or fileOrFolder.isFolder%}
        <div x-show="isOpen" style="display:none" class="{{'filelist' if step>0}}">
            {%if fileOrFolder.isNote and not fileOrFolder.hide %}
                <div @click.stop class="notelink {{ 'active-note' if fileOrFolder.permalink === page.url }}">
                    <a data-note-icon="{{fileOrFolder.noteIcon}}" style="text-decoration: none;" class="filename" href="{{fileOrFolder.permalink}}">{{fileOrFolder.name}} </a>
                </div>
            {% elif fileOrFolder.isFolder%}
                <div class="folder inner-folder"  x-data="{isOpen: $persist({{ 'true' if step < 1 else 'false' }}).as('dgft1:'+{{ currentPath | dump }})}" @click.stop="isOpen=!isOpen">
                    <div class="foldername-wrapper align-icon">
                    <i x-show="isOpen" style="display: none;"  data-lucide="chevron-down"></i>
                    <i x-show="!isOpen"  data-lucide="chevron-right"></i>
                    <span class="foldername">{{fileOrFolderName}}</span>
                    </div>
                    {% for fileOrFolderName, child in fileOrFolder %}
                        {{menuItem(fileOrFolderName, child, step+1, (currentPath+"/"+fileOrFolderName))}}
                    {% endfor %}
                </div>
            {% endif %}
        </div>
        {%endif%}
    {% endmacro %}
    
    <div x-init="isDesktop = (window.innerWidth>=1000) ? true: false;"
            x-on:resize.window="isDesktop = (window.innerWidth>=1000) ? true : false;"
            x-data="{isDesktop: true, showFilesMobile: false, filetreeExpanded: $persist(true).as('filetreeExpanded')}">

        <div x-show.important="!isDesktop" style="display: none;">
            {%include "components/filetreeNavbar.njk"%}
        </div>
        
        <div x-show="showFilesMobile && !isDesktop" @click="showFilesMobile = false" style="display:none;" class="fullpage-overlay"></div>

      <div class="filetree-wrapper" x-show.important="isDesktop || showFilesMobile" style="display: none;"
           :class="{ 'is-collapsed': !filetreeExpanded }"
           x-effect="document.body.classList.toggle('filetree-collapsed', !filetreeExpanded)">
      <nav class="filetree-sidebar">
        <button type="button" class="filetree-toggle-btn" @click="filetreeExpanded = !filetreeExpanded" title="展开/收起侧边栏" aria-label="展开/收起侧边栏">
          <i data-lucide="panel-left-close" x-show="filetreeExpanded" style="display: none;"></i>
          <i data-lucide="panel-left-open" x-show="!filetreeExpanded" style="display: none;"></i>
        </button>
        {% for imp in dynamics.filetree.beforeTitle %}
            {% include imp %}
        {% endfor %}
         {% if meta.siteLogoPath %}
         <a href="/" style="text-decoration: none; display: flex; justify-content: center;">
                   <img class="site-logo" src="{{meta.siteLogoPath}}" alt="{{meta.siteName}}">
         </a>
         {% else %}
         <a href="/" style="text-decoration: none; text-align: center;">
                   <h1 style="text-align:center;">{{meta.siteName}}</h1>
         </a>
         {% endif %}
         {% for imp in dynamics.filetree.afterTitle %}
            {% include imp %}
        {% endfor %}
        {% if settings.dgEnableSearch === true%}
            {% include "components/searchButton.njk" %}
        {%endif%}
         <div id="dg-filetree-scroll-container" class="folder" x-data="{isOpen: true}">
               {%- for fileOrFolderName, fileOrFolder in filetree -%}
                  {{menuItem(fileOrFolderName, fileOrFolder, 0, fileOrFolderName)}}
               {%- endfor -%}
         </div>
      </nav>
      </div>
    </div>
    <script>
    (function () {
      var KEY = 'dg-filetree-scroll';
      function scrollRoot() {
        return document.getElementById('dg-filetree-scroll-container');
      }
      function saveScroll() {
        var el = scrollRoot();
        if (el) try { sessionStorage.setItem(KEY, String(el.scrollTop)); } catch (e) {}
      }
      function restoreScroll() {
        var el = scrollRoot();
        if (!el) return;
        var v = sessionStorage.getItem(KEY);
        if (v == null || v === '') return;
        var n = parseFloat(v);
        if (!isNaN(n)) el.scrollTop = n;
      }
      var folderEl = scrollRoot();
      if (folderEl) {
        var scrollTimer;
        folderEl.addEventListener('scroll', function () {
          clearTimeout(scrollTimer);
          scrollTimer = setTimeout(saveScroll, 100);
        }, { passive: true });
      }
      document.addEventListener('click', function (e) {
        var a = e.target.closest && e.target.closest('.filetree-sidebar a[href]');
        if (!a) return;
        var href = a.getAttribute('href') || '';
        if (!href || href === '#' || href.indexOf('javascript:') === 0) return;
        if (e.defaultPrevented) return;
        if (e.metaKey || e.ctrlKey || e.shiftKey || e.altKey) return;
        if (a.target === '_blank') return;
        saveScroll();
      }, true);
      function scheduleRestore() {
        restoreScroll();
        requestAnimationFrame(function () {
          restoreScroll();
          requestAnimationFrame(restoreScroll);
        });
      }
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', scheduleRestore);
      } else scheduleRestore();
      window.addEventListener('pageshow', function (ev) {
        if (ev.persisted) scheduleRestore();
      });
      window.addEventListener('load', function () {
        setTimeout(scheduleRestore, 0);
        setTimeout(scheduleRestore, 100);
      });
    })();
    </script>
