<!DOCTYPE html>
<html lang="{{ meta.mainLanguage }}">
  <head>
    <title>{% if title %}{{ title }}{% else %}{{ page.fileSlug }}{% endif %}</title>
    {%include "components/pageheader.njk"%}
    {% for imp in dynamics.common.head %}
      {% include imp %}
    {% endfor %}
    {% for imp in dynamics.notes.head %}
      {% include imp %}
    {% endfor %}
  </head>
  <body class="theme-{{meta.baseTheme}} markdown-preview-view markdown-rendered markdown-preview-section {% if settings.dgShowFileTree !== true %}no-filetree{% endif %} {% if settings.dgHomeLink === true and settings.dgShowFileTree !== true %}has-navbar{% endif %} {{meta.bodyClasses}}">
    <script>(function(){var s=localStorage.getItem('dg-theme');if(s==='light'){document.body.classList.remove('theme-dark');document.body.classList.add('theme-light');}})();</script>
    {%include "components/notegrowthhistory.njk"%}
    
    {% if settings.dgShowFileTree !== true %}
      {%include "components/navbar.njk"%}
    {%else%}
      {%include "components/filetree.njk"%}
    {% endif %}

    {% if settings.dgEnableSearch === true %}
      {%include "components/searchContainer.njk"%}
    {% endif %}

    <main class="content cm-s-obsidian print {{contentClasses}}">
      <header>
        {% if settings.dgShowInlineTitle === true %}
          <h1 data-note-icon="{% if noteIcon %}{{noteIcon}}{% else %}{{meta.noteIconsSettings.default}}{% endif %}">{% if title %}{{ title }}{% else %}{{ page.fileSlug }}{% endif %}</h1>
        {% endif %}
        <div class="header-meta">
          {% if settings.dgShowTags === true and tags %}
            <div class="header-tags">
              {% for tag in tags %}
                {% if tag != 'gardenEntry' and tag !='note' %}
                  <a class="tag" onclick="toggleTagSearch(this)">
                    #{{tag}}
                  </a>
                {% endif %}
              {% endfor %}
            </div>
          {% endif %}
          {%- if meta.timestampSettings.showCreated or meta.timestampSettings.showUpdated -%}
          <div class="timestamps">
            {%- if meta.timestampSettings.showCreated and created -%}
            <div><i data-lucide="calendar-plus"></i> <span class="human-date" data-date="{{created}}"></span></div>
            {%- endif -%}
            {%- if meta.timestampSettings.showUpdated and updated -%}
            <div><i data-lucide="calendar-clock"></i> <span class="human-date" data-date="{{updated}}"></span></div>
            {%- endif -%}
          </div>
          {%- endif -%}
        </div>
      {% for imp in dynamics.common.header %}
        {% include imp %}
      {% endfor %}
      {% for imp in dynamics.notes.header %}
        {% include imp %}
      {% endfor %}
      </header>
      {% for imp in dynamics.common.beforeContent %}
        {% include imp %}
      {% endfor %}
      {% for imp in dynamics.notes.beforeContent %}
        {% include imp %}
      {% endfor %}
      {% if mindmapPlugin == "markdown" %}
      <div id="dg-mindmap-wrapper" class="dg-mindmap-wrapper">
        <div class="dg-mindmap-toolbar">
          <button id="dg-mindmap-toggle" type="button" class="clickable-icon">显示原文</button>
        </div>
        <svg id="dg-mindmap" class="dg-mindmap"></svg>
      </div>
      {% endif %}
      {{ content | hideDataview | taggify | link | safe}}
      {% for imp in dynamics.common.afterContent %}
        {% include imp %}
      {% endfor %}
      {% for imp in dynamics.notes.afterContent %}
        {% include imp %}
      {% endfor %}
    </main>

    {% if settings.dgShowBacklinks === true or settings.dgShowLocalGraph === true or settings.dgShowToc === true%}
      {%include "components/sidebar.njk"%}
    {% endif %}

    {% if settings.dgLinkPreview === true %}
      {%include "components/linkPreview.njk"%}
    {% endif %}
    {% include "components/references.njk" %}
    {% include "components/timestamps.njk" %}
    {% for imp in dynamics.common.footer %}
      {% include imp %}
    {% endfor %}
    {% for imp in dynamics.notes.footer %}
      {% include imp %}
    {% endfor %}
    {%include "components/lucideIcons.njk"%}
    {% if contentClasses and "canvas-page" in contentClasses %}
      {%include "components/canvasScript.njk"%}
    {% endif %}
    {% if mindmapPlugin == "markdown" %}
    <script>
      (function () {
        function loadScript(src) {
          return new Promise(function (resolve, reject) {
            var s = document.createElement("script");
            s.src = src;
            s.async = true;
            s.onload = resolve;
            s.onerror = function () {
              reject(new Error("加载失败: " + src));
            };
            document.head.appendChild(s);
          });
        }

        function toOutlineMarkdown(main) {
          var title = (main.querySelector("header h1") || {}).textContent || "思维导图";
          var headings = Array.from(main.querySelectorAll("h1,h2,h3,h4,h5,h6"))
            .filter(function (el) { return el.closest("#dg-mindmap-wrapper") == null; });
          var lines = ["# " + title.trim()];
          if (!headings.length) return lines.join("\n");
          headings.forEach(function (h) {
            var text = (h.textContent || "").trim();
            if (!text) return;
            var level = Number(h.tagName.slice(1));
            var indent = "  ".repeat(Math.max(0, level - 2));
            lines.push(indent + "- " + text);
          });
          return lines.join("\n");
        }

        var main = document.querySelector("main.content");
        var svg = document.getElementById("dg-mindmap");
        var wrapper = document.getElementById("dg-mindmap-wrapper");
        var toggle = document.getElementById("dg-mindmap-toggle");
        if (!main || !svg || !wrapper) return;

        var D3_CDN = "https://fastly.jsdelivr.net/npm/d3@7/dist/d3.min.js";
        var D3_FALLBACK = "https://cdn.jsdelivr.net/npm/d3@7/dist/d3.min.js";
        var LIB_CDN = "https://fastly.jsdelivr.net/npm/markmap-lib@0.18.12/dist/browser/index.iife.js";
        var VIEW_CDN = "https://fastly.jsdelivr.net/npm/markmap-view@0.18.12/dist/browser/index.js";
        var LIB_FALLBACK = "https://cdn.jsdelivr.net/npm/markmap-lib@0.18.12/dist/browser/index.iife.js";
        var VIEW_FALLBACK = "https://cdn.jsdelivr.net/npm/markmap-view@0.18.12/dist/browser/index.js";

        function loadWithFallback(primary, fallback) {
          return loadScript(primary).catch(function () {
            return loadScript(fallback);
          });
        }

        Promise.resolve()
          .then(function () { return loadWithFallback(D3_CDN, D3_FALLBACK); })
          .then(function () { return loadWithFallback(LIB_CDN, LIB_FALLBACK); })
          .then(function () { return loadWithFallback(VIEW_CDN, VIEW_FALLBACK); })
          .then(function () {
            var markmap = window.markmap || {};
            var Transformer = markmap.Transformer;
            var Markmap = markmap.Markmap;
            if (!Transformer || !Markmap) throw new Error("markmap 全局对象不可用");

            var markdown = toOutlineMarkdown(main);
            var transformer = new Transformer();
            var transformed = transformer.transform(markdown);
            Markmap.create(svg, {
              autoFit: true,
              duration: 300,
              fitRatio: 0.9,
              maxWidth: 320
            }, transformed.root);

            main.classList.add("dg-mindmap-mode");
          })
          .catch(function (err) {
            console.error("[dg-mindmap]", err);
            main.classList.add("dg-mindmap-mode");
          })
          .finally(function () {
            if (toggle) {
              toggle.addEventListener("click", function () {
                main.classList.toggle("dg-show-raw-content");
                toggle.textContent = main.classList.contains("dg-show-raw-content") ? "隐藏原文" : "显示原文";
              });
            }
          });
      })();
    </script>
    <style>
      .dg-mindmap-wrapper {
        border: 1px solid var(--background-modifier-border);
        border-radius: 12px;
        margin: 12px 0 18px;
        background: var(--background-secondary);
        overflow: hidden;
      }
      .dg-mindmap-toolbar {
        display: flex;
        justify-content: flex-end;
        padding: 8px 10px;
        border-bottom: 1px solid var(--background-modifier-border);
      }
      .dg-mindmap-toolbar .clickable-icon {
        cursor: pointer;
        border: 1px solid var(--background-modifier-border);
        border-radius: 8px;
        padding: 4px 10px;
        background: var(--background-primary);
        color: var(--text-normal);
      }
      .dg-mindmap {
        display: block;
        width: 100%;
        height: min(72vh, 760px);
        background: var(--background-primary);
      }
      main.content.dg-mindmap-mode > *:not(header):not(#dg-mindmap-wrapper) {
        display: none;
      }
      main.content.dg-mindmap-mode.dg-show-raw-content > *:not(header):not(#dg-mindmap-wrapper) {
        display: revert;
      }
    </style>
    {% endif %}
  </body>
</html>
